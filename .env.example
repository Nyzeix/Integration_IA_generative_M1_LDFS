# Copiez ce fichier en .env et remplissez au moins UNE clé.
# cp .env.example .env
#
# Le cours détecte automatiquement quelle API est disponible.
# Ordre de priorité : Groq (gratuit) > OpenAI (payant) > Ollama (local gratuit).

# --- OPTION 1 : Groq (RECOMMANDE - gratuit) ---
# Créez un compte sur https://console.groq.com
# Générez une clé API dans Settings > API Keys
# Modèles disponibles gratuitement : llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_API_KEY=gsk_votre_cle_groq_ici

# --- OPTION 2 : OpenAI (payant) ---
# Créez un compte sur https://platform.openai.com
# Crédits gratuits limités pour les nouveaux comptes
# OPENAI_API_KEY=sk-votre_cle_openai_ici

# --- OPTION 3 : Ollama (local, gratuit, sans clé) ---
# Installez Ollama depuis https://ollama.com
# Lancez : ollama pull llama3.1
# Puis : ollama serve
# Aucune clé nécessaire, décommentez juste la ligne suivante :
# OLLAMA_URL=http://localhost:11434/v1

# --- Hugging Face (Room 03 uniquement) ---
# Créez un compte sur https://huggingface.co
# Générez un token dans Settings > Access Tokens
HF_TOKEN=hf_votre_token_huggingface_ici
